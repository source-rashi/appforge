# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://appforge:appforge@localhost:5432/appforge

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — generate with: openssl rand -base64 64
JWT_SECRET=change_me_before_deploying_this_is_not_secure

# ─── API Server ──────────────────────────────────────────────────────────────
# Port the Express API listens on
PORT=4000

# ─── Frontend ────────────────────────────────────────────────────────────────
# Public base URL of the API (accessible from the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
